import { Theme, UISize, ButtonVariant } from "@ui/theme.slint";
import { Callbacks, Browser, Editor, Ui, FileRow } from "callbacks.slint";
import { Button } from "@ui/button.slint";
import { Icon } from "@ui/icon.slint";
import { Input } from "@ui/input.slint";
import { SegmentedControl } from "@ui/segmented_control.slint";
import { Dialog, DialogVariant } from "@ui/dialog.slint";

export { Callbacks, Browser, Editor, Ui, FileRow, Theme }

// A round icon button built from a raw TouchArea. The SDK IconButton sizes its
// touch area to a fixed control-size rather than the laid-out size, so its
// clicks don't register once a layout gives it a different size — a plain
// TouchArea (as used for the file rows and menu) is reliable.
component IconBtn inherits Rectangle {
    in property <image> icon;
    in property <color> icon-color: Theme.palette-foreground;
    in property <length> diameter: 44px;
    callback clicked();

    width: diameter;
    height: diameter;
    border-radius: diameter / 2;
    background: touch.pressed
        ? Theme.palette-secondary-pressed
        : (touch.has-hover ? Theme.palette-secondary : Theme.palette-secondary.with-alpha(0.4));

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }
    Icon {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: root.diameter * 0.5;
        icon: root.icon;
        icon-color: root.icon-color;
    }
}

// A scrollable, on-theme multiline text editor: a Flickable (drag-scroll) around
// a builtin TextInput with cursor-following (the textedit-base.slint pattern).
// The SDK TextArea can't scroll (it clips past max-rows), so we roll our own.
component EditorField inherits Rectangle {
    in-out property <string> text;
    in property <string> placeholder;
    out property <bool> has-focus: input.has-focus;
    forward-focus: input;

    property <length> pad: 16px;

    background: Theme.palette-secondary;
    border-radius: 16px;
    clip: true;

    fly := Flickable {
        x: root.pad;
        y: root.pad;
        width: parent.width - 2 * root.pad;
        height: parent.height - 2 * root.pad;
        viewport-width: self.width;
        viewport-height: max(self.height, input.preferred-height);

        input := TextInput {
            width: parent.width;
            text <=> root.text;
            color: Theme.palette-foreground;
            font-family: "SourceCodePro";
            font-size: 18px;
            single-line: false;
            wrap: word-wrap;
            vertical-alignment: top;
            page-height: fly.height;

            // Keep the cursor visible as the user types / navigates.
            cursor-position-changed(cpos) => {
                if (cpos.y + fly.viewport-y < 12px) {
                    fly.viewport-y = min(0px, max(fly.height - self.height, -cpos.y + 12px));
                } else if (cpos.y + fly.viewport-y > fly.height - 12px - 24px) {
                    fly.viewport-y = min(0px, max(fly.height - self.height, fly.height - cpos.y - 12px - 24px));
                }
            }
        }
    }

    Text {
        x: root.pad;
        y: root.pad;
        width: parent.width - 2 * root.pad;
        text: root.text == "" && input.preedit-text == "" ? root.placeholder : "";
        color: Theme.palette-muted;
        font-family: "SourceCodePro";
        font-size: 18px;
    }
}

// A single row in the file list.
component FileEntry inherits Rectangle {
    in property <FileRow> entry;
    height: 60px;
    background: touch.has-hover ? Theme.palette-secondary : transparent;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 12px;

        Icon {
            width: 24px;
            icon: root.entry.is-folder ? @image-url("icons/folder.svg") : @image-url("icons/file.svg");
            icon-color: root.entry.is-folder ? Theme.palette-primary : Theme.palette-foreground;
        }

        touch := TouchArea {
            horizontal-stretch: 1;
            clicked => {
                Callbacks.entry-activated(root.entry.name, root.entry.is-folder);
            }
            VerticalLayout {
                alignment: center;
                Text {
                    text: root.entry.name;
                    color: Theme.palette-foreground;
                    font-family: "Montserrat";
                    font-size: 18px;
                    overflow: elide;
                }
                Text {
                    text: root.entry.info;
                    color: Theme.palette-muted;
                    font-family: "Montserrat";
                    font-size: 13px;
                }
            }
        }

        IconBtn {
            icon: @image-url("icons/pencil.svg");
            clicked => {
                Ui.target-name = root.entry.name;
                Ui.input-text = root.entry.name;
                Ui.show-rename = true;
            }
        }
        IconBtn {
            icon: @image-url("icons/trash-2.svg");
            icon-color: Theme.palette-danger;
            clicked => {
                Ui.target-name = root.entry.name;
                Ui.show-delete = true;
            }
        }
    }

    Rectangle {
        y: parent.height - 1px;
        height: 1px;
        background: Theme.palette-border;
    }
}

// A row inside the ••• dropdown menu.
component MenuRow inherits Rectangle {
    in property <string> text;
    in property <image> icon;
    callback triggered();
    height: 52px;
    background: touch.has-hover ? Theme.palette-secondary : transparent;

    touch := TouchArea {
        clicked => {
            root.triggered();
        }
    }
    HorizontalLayout {
        padding-left: 16px;
        padding-right: 16px;
        spacing: 12px;
        Text {
            vertical-alignment: center;
            horizontal-stretch: 1;
            text: root.text;
            color: Theme.palette-foreground;
            font-family: "Montserrat";
            font-size: 17px;
            font-weight: 600;
        }
        Icon {
            width: 20px;
            icon: root.icon;
        }
    }
}

// A centered modal with one text field (used for New file / New folder / Rename).
component NamePrompt inherits Rectangle {
    in property <string> title;
    in property <string> confirm-label;
    in property <string> placeholder: "Name";
    callback confirmed(string);
    callback cancelled();

    background: rgba(0, 0, 0, 0.55);

    TouchArea {
        clicked => {
            root.cancelled();
        }
    }

    Rectangle {
        width: 86%;
        height: 214px;
        background: Theme.palette-surface;
        border-radius: 16px;
        border-width: 1px;
        border-color: Theme.palette-border;

        // Swallow taps on the panel so they don't dismiss.
        TouchArea {}

        VerticalLayout {
            padding: 24px;
            spacing: 16px;

            Text {
                text: root.title;
                color: Theme.palette-foreground;
                font-family: "Montserrat";
                font-size: 20px;
                font-weight: 600;
            }
            Input {
                value <=> Ui.input-text;
                placeholder: root.placeholder;
            }
            HorizontalLayout {
                spacing: 12px;
                Button {
                    full-width: true;
                    variant: ButtonVariant.secondary;
                    text: "Cancel";
                    clicked => {
                        root.cancelled();
                    }
                }
                Button {
                    full-width: true;
                    text: root.confirm-label;
                    clicked => {
                        root.confirmed(Ui.input-text);
                    }
                }
            }
        }
    }
}

// The browse screen: tabs + ••• menu, path row, scrollable list.
component BrowserView inherits VerticalLayout {
    spacing: 12px;

    HorizontalLayout {
        // Match the SegmentedControl's natural height (md control 56 + 2×4 list
        // padding = 64) so the tabs bar and the kebab are the same height and
        // vertically centered.
        height: 64px;
        spacing: 8px;
        SegmentedControl {
            horizontal-stretch: 1;
            options: ["Internal", "Airlock", "USB"];
            selected-index <=> Browser.location-index;
            changed(idx, label) => {
                Callbacks.location-changed(idx);
            }
        }
        IconBtn {
            icon: @image-url("icons/ellipsis.svg");
            diameter: 64px;
            clicked => {
                Ui.show-menu = !Ui.show-menu;
            }
        }
    }

    HorizontalLayout {
        spacing: 8px;
        height: 48px;

        if !Browser.at-root: IconBtn {
            icon: @image-url("icons/arrow-left.svg");
            clicked => {
                Callbacks.go-back();
            }
        }
        Text {
            vertical-alignment: center;
            horizontal-stretch: 1;
            text: Browser.path;
            color: Theme.palette-muted;
            font-family: "Montserrat";
            font-size: 15px;
            overflow: elide;
        }
    }

    if Ui.message != "": Text {
        text: Ui.message;
        color: Ui.message-error ? Theme.palette-danger : Theme.palette-primary;
        font-family: "Montserrat";
        font-size: 14px;
    }
    if Browser.status != "": Text {
        text: Browser.status;
        color: Theme.palette-muted;
        font-family: "Montserrat";
        font-size: 16px;
        horizontal-alignment: center;
    }

    Flickable {
        vertical-stretch: 1;
        viewport-height: Browser.entries.length * 60px;
        VerticalLayout {
            alignment: start;
            spacing: 0px;
            for item in Browser.entries: FileEntry {
                entry: item;
            }
        }
    }
}

// The editor screen: header (back / name / save) + text field.
// Explicit geometry (not a VerticalLayout): the header is pinned at the top and
// the TextArea below it, so the TextArea can never overlap and swallow the
// header buttons' taps.
component EditorView inherits Rectangle {
    // Header bar.
    HorizontalLayout {
        x: 0;
        y: 0;
        width: parent.width;
        height: 56px;
        spacing: 8px;

        IconBtn {
            icon: @image-url("icons/arrow-left.svg");
            clicked => {
                Callbacks.close-editor();
            }
        }
        Text {
            vertical-alignment: center;
            horizontal-stretch: 1;
            text: Editor.filename;
            color: Theme.palette-foreground;
            font-family: "Montserrat";
            font-size: 18px;
            font-weight: 600;
            overflow: elide;
        }
        IconBtn {
            icon: @image-url("icons/save.svg");
            clicked => {
                // Blur the field first so the on-screen keyboard closes (goal 1),
                // then save.
                editor-field.clear-focus();
                Callbacks.save-file();
            }
        }
    }

    // Editor body, pinned below the header. Fills the space when unfocused
    // (no gap); shrinks above the 396px keyboard overlay when focused so its
    // content stays visible and scrollable. (~376px = 396 − 20px bottom padding.)
    editor-field := EditorField {
        x: 0;
        y: 68px;
        width: parent.width;
        height: self.has-focus
            ? parent.height - 68px - 340px
            : parent.height - 68px;
        text <=> Editor.content;
        placeholder: "Empty file";
    }
}

export component AppWindow inherits Window {
    title: "Text Editor";
    preferred-width: 480px;
    preferred-height: 800px;
    background: Theme.palette-background;

    Rectangle {
        width: parent.width;
        height: parent.height;
        background: Theme.palette-background;

        // Main content.
        VerticalLayout {
            padding-left: 20px;
            padding-right: 20px;
            padding-top: 24px + UISize.control-center-status-bar-height;
            padding-bottom: 20px;

            if !Ui.editing: BrowserView {}
            if Ui.editing: EditorView {}
        }

        // --- Overlays (later siblings render on top of the content) ---

        // ••• dropdown, anchored top-right under the menu button.
        if Ui.show-menu: Rectangle {
            width: 100%;
            height: 100%;
            TouchArea {
                clicked => {
                    Ui.show-menu = false;
                }
            }
            Rectangle {
                x: parent.width - self.width - 20px;
                y: 20px + UISize.control-center-status-bar-height + 44px;
                width: 230px;
                height: 176px;
                background: Theme.palette-surface;
                border-radius: 14px;
                border-width: 1px;
                border-color: Theme.palette-border;

                VerticalLayout {
                    padding-top: 6px;
                    padding-bottom: 6px;
                    MenuRow {
                        text: "New file";
                        icon: @image-url("icons/file.svg");
                        triggered => {
                            Ui.show-menu = false;
                            Ui.input-text = "";
                            Ui.show-new = true;
                        }
                    }
                    Rectangle {
                        height: 1px;
                        background: Theme.palette-border;
                    }
                    MenuRow {
                        text: "New folder";
                        icon: @image-url("icons/folder.svg");
                        triggered => {
                            Ui.show-menu = false;
                            Ui.input-text = "";
                            Ui.show-new-folder = true;
                        }
                    }
                    Rectangle {
                        height: 1px;
                        background: Theme.palette-border;
                    }
                    MenuRow {
                        text: Ui.show-hidden ? "Hide hidden files" : "Show hidden files";
                        icon: @image-url("icons/eye.svg");
                        triggered => {
                            Ui.show-menu = false;
                            Callbacks.toggle-hidden();
                        }
                    }
                }
            }
        }

        if Ui.show-new: NamePrompt {
            width: 100%;
            height: 100%;
            title: "New file";
            confirm-label: "Create";
            placeholder: "File name";
            confirmed(name) => {
                Ui.show-new = false;
                Callbacks.new-file(name);
            }
            cancelled => {
                Ui.show-new = false;
            }
        }

        if Ui.show-new-folder: NamePrompt {
            width: 100%;
            height: 100%;
            title: "New folder";
            confirm-label: "Create";
            placeholder: "Folder name";
            confirmed(name) => {
                Ui.show-new-folder = false;
                Callbacks.new-folder(name);
            }
            cancelled => {
                Ui.show-new-folder = false;
            }
        }

        if Ui.show-rename: NamePrompt {
            width: 100%;
            height: 100%;
            title: "Rename";
            confirm-label: "Rename";
            placeholder: "New name";
            confirmed(name) => {
                Ui.show-rename = false;
                Callbacks.rename-entry(Ui.target-name, name);
            }
            cancelled => {
                Ui.show-rename = false;
            }
        }

        if Ui.show-delete: Dialog {
            width: 100%;
            height: 100%;
            open: true;
            title: "Delete";
            message: "Delete \"" + Ui.target-name + "\"?";
            primary-action: "Delete";
            secondary-action: "Cancel";
            variant: DialogVariant.danger;
            primary-clicked => {
                Ui.show-delete = false;
                Callbacks.delete-entry(Ui.target-name);
            }
            secondary-clicked => {
                Ui.show-delete = false;
            }
            dismissed => {
                Ui.show-delete = false;
            }
        }
    }
}
